{% extends "layouts/base.njk" %}
{% block main %}
<section class="cv-page">
  <header class="page-title"><h1>{{ title }}</h1></header>
  <div class="cv-layout">
    <figure class="cv-portrait"><img src="{{ portrait }}" alt="{{ portraitAlt }}"></figure>
    <div class="cv-copy">{{ content | safe }}</div>
  </div>
</section>
{% endblock %}
