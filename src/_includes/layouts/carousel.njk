{% extends "layouts/base.njk" %}
{% block main %}
<section class="portfolio-page carousel carousel-{{ galleryLayout }}" data-carousel tabindex="0" aria-label="{{ title }} artwork carousel">
  <div class="carousel-viewport">
    <div class="art-grid carousel-track">
      {% for image in images %}
      <figure class="gallery-item carousel-slide {{ image.orientation }}" data-carousel-slide>
        <img src="{{ image.src }}" alt="{{ image.alt }}"{% if not loop.first %} loading="lazy"{% endif %} decoding="async">
      </figure>
      {% endfor %}
    </div>
  </div>
  {% if images.length > 1 %}
  <button class="gallery-control gallery-control-prev" type="button" aria-label="Previous artwork">‹</button>
  <button class="gallery-control gallery-control-next" type="button" aria-label="Next artwork">›</button>
  <p class="visually-hidden" aria-live="polite" data-carousel-status></p>
  {% endif %}
</section>
{% endblock %}
