<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>{{ title }} — Genevra Daley</title>
  <meta name="description" content="Genevra Daley — artist portfolio">
  <link rel="stylesheet" href="/assets/site.css">
  <script defer src="/assets/site.js"></script>
</head>
<body class="site-daley {{ pageClass }}">
  <a class="skip-link" href="#content">Skip to content</a>
  {% include "partials/header.njk" %}
  <main id="content">{% block main %}{{ content | safe }}{% endblock %}</main>
  <footer class="site-footer"><p>© Genevra Daley</p></footer>
  <dialog class="lightbox"><button class="lightbox-close" aria-label="Close image">×</button><img alt=""><p></p></dialog>
</body>
</html>
